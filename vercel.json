{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://rat-backend-production.up.railway.app/api/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "https://rat-backend-production.up.railway.app/ws/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
